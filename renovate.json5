{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  // `config:recommended` brings the dependency dashboard, monorepo
  // groupings, and semantic commit prefixes. The pin-helper makes
  // every GitHub Action update keep the repo's existing
  // `sha # vX.Y.Z` pinning style.
  extends: [
    "config:recommended",
    "helpers:pinGitHubActionDigestsToSemver",
  ],

  timezone: "Etc/UTC",
  schedule: ["before 6am on monday"],

  assignees: ["s0undt3ch"],
  labels: ["dependencies"],

  packageRules: [
    // ---- Ecosystem labels (mirror the old Dependabot setup) ----
    {
      description: "Tag Rust crate updates",
      matchManagers: ["cargo"],
      addLabels: ["dependencies:rust"],
    },
    {
      description: "Tag Python (pyproject.toml) updates",
      matchManagers: ["pep621"],
      addLabels: ["dependencies:python"],
    },
    {
      description: "Tag GitHub Actions updates",
      matchManagers: ["github-actions"],
      addLabels: ["dependencies:github-actions"],
    },
    {
      description: "Tag mise Python / uv pins as Python",
      matchManagers: ["mise"],
      matchDepNames: ["python", "uv"],
      addLabels: ["dependencies:python"],
    },
    {
      description: "Tag mise Rust tooling pins as Rust",
      matchManagers: ["mise"],
      matchDepNames: ["rust", "cargo-edit"],
      addLabels: ["dependencies:rust"],
    },

    // ---- Grouping to cut PR noise ----
    {
      // The three ruff_* crates share one astral-sh/ruff git tag —
      // they must move in lockstep. They're declared as cargo git
      // deps, so Renovate routes them through the `git-tags`
      // datasource and the `packageName` becomes the git URL
      // (`https://github.com/astral-sh/ruff`), not the crate name.
      // Match by `depName` (the manifest-side crate identifier)
      // instead — same shape as the `mise tools` rule below.
      description: "Group ruff_* crates",
      groupName: "ruff crates",
      matchManagers: ["cargo"],
      matchDepNames: [
        "ruff_python_ast",
        "ruff_python_parser",
        "ruff_text_size",
      ],
    },
    {
      // GHA digest pins drift constantly; reviewing one weekly PR is
      // saner than ~20 individual ones.
      description: "Group all GitHub Actions updates",
      groupName: "github-actions",
      matchManagers: ["github-actions"],
    },
    {
      // mise CLI tools (actionlint, shellcheck, prek) — group them so
      // we don't get a PR per tool. Python and Rust toolchains stay
      // in their own ecosystem-tagged PRs so language bumps remain
      // reviewable on their own.
      description: "Group mise CLI tooling updates",
      groupName: "mise tools",
      matchManagers: ["mise"],
      matchDepNames: ["actionlint", "shellcheck", "prek"],
    },
  ],
}
